	measure Title_Trend_Select_With_PY = ```
			
			VAR metric = SELECTEDVALUE(Metrics[Metric])
			
			VAR trend_score = 
			    SWITCH(
			        metric,
			        "Satisfaction Score", [Trend_Satisfaction],
			        "Wait Time", [Trend_Wait_Times],
			        "Patient Count", [Trend_Patient_Count]
			    )
			
			VAR direction = IF(trend_score >= 0, "Up", "Down")
			
			VAR output = 
			    SWITCH(
			        metric,
			        "Satisfaction Score", metric & " With PY (Trending " & direction & ")",
			        "Wait Time", metric & " With PY (Trending " & direction & ")",
			        "Patient Count", metric & " With PY (Trending " & direction & ")"
			    )
			
			RETURN 
			    output
			```
		displayFolder: _Formatting
		lineageTag: 9c7c4546-f7ac-40e4-844d-c96d5889cf7e

