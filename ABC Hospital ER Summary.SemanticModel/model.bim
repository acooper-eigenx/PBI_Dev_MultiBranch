        ],
        "lineageTag": "d1619ac6-ae2f-4653-b7f3-a1857d7ddcbe",
        "partitions": [
          {
            "name": "Time_Of_Day",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    // Define the start time",
                "    StartTime = #time(0, 0, 0),",
                "    ",
                "    // Calculate the total minutes in a 24-hour period (1440 minutes)",
                "    TotalMinutes = 1440,",
                "    ",
                "    // Create a list of times, increasing by one minute",
                "    TimeList = List.Times(StartTime, TotalMinutes, #duration(0, 0, 1, 0)),",
                "    ",
                "    // Convert the list to a table",
                "    TimeTable = Table.FromList(TimeList, Splitter.SplitByNothing()),",
                "    ",
                "    // Rename the column",
                "    #\"Renamed Columns\" = Table.RenameColumns(TimeTable, {{\"Column1\", \"Time\"}}),",
                "    ",
                "    // Change the column type to time",
                "    #\"Changed Type\" = Table.TransformColumnTypes(#\"Renamed Columns\", {{\"Time\", type time}}),",
                "    #\"Renamed Columns1\" = Table.RenameColumns(#\"Changed Type\",{{\"Time\", \"Time_Of_Day\"}}),",
                "    #\"Inserted Hour\" = Table.AddColumn(#\"Renamed Columns1\", \"Hour\", each Time.Hour([Time_Of_Day]), Int64.Type),",
                "    #\"Added Custom\" = Table.AddColumn(#\"Inserted Hour\", \"Time_Bucket\", each if [Hour] < 8 then \"Morning\"",
                "else if [Hour] >= 8 and [Hour] < 16 then \"Afternoon\"",
                "else \"Night\")",
                "in",
                "    #\"Added Custom\""
              ],
              "type": "m"
            }
          }
        ]
      },
