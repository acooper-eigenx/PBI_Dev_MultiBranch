          },
          {
            "name": "Count_Patient_Visits",
            "expression": [
              "CALCULATE(",
              "    COUNTROWS(VALUES(Hospital_Data)),",
              "    ALLEXCEPT(Hospital_Data, Hospital_Data[patient_first_initial], Hospital_Data[patient_last_name])",
              ")"
            ],
            "formatString": "#,0",
