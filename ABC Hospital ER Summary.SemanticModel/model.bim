                "let",
                "    Source = Csv.Document(File.Contents(\"C:\\Users\\AndrewCooper\\OneDrive - Eigen X LLC\\PBI\\Hospital Dashboard\\Hospital_ER_Data_20240826.csv\"),[Delimiter=\",\", Columns=13, Encoding=1252, QuoteStyle=QuoteStyle.None]),",
                "    #\"Promoted Headers\" = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),",
