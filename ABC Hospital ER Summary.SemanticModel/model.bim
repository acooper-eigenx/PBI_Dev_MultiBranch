          {
            "name": "Title_Trend_Patients",
            "displayFolder": "_Formatting",
            "expression": [
              "",
              "VAR direction = IF([Trend_Patient_Count] >= 0, \"Up\", \"Down\")",
              "",
              "RETURN ",
              "    \"Patient Count (Trending \" & direction & \")\""
            ],
            "lineageTag": "2613e0de-e16f-495e-aa34-8c72c3237096"
          },
          {
            "name": "Title_Trend_Satisfaction",
            "displayFolder": "_Formatting",
            "expression": [
              "",
              "VAR direction = IF([Trend_Line_Satisfaction] >= 0, \"Up\", \"Down\")",
              "",
              "VAR avg_val = FORMAT( [Avg_Sat_Score], \"#,##0.#0\" )",
              "",
              "RETURN ",
              "    \"Patient Satisfaction (Trending \" & direction & \") - Avg: \" & avg_val "
            ],
            "lineageTag": "aa434be1-3013-4577-9197-cdf41beb3409"
          },
          {
            "name": "Title_Trend_Wait_Times",
            "displayFolder": "_Formatting",
            "expression": [
              "",
              "VAR direction = IF([Trend_Wait_Times] >= 0, \"Up\", \"Down\")",
              "",
              "VAR avg_val = FORMAT( [Avg_Wait_Time], \"#,##0.#0\" )",
              "",
              "RETURN ",
              "    \"Patient Wait Times (Trending \" & direction & \") - Avg: \" & avg_val "
            ],
            "lineageTag": "ce2382d0-bb5d-4f37-8358-0e88cc8f7d33"
          },
          {
            "name": "Title_Trend_Select",
            "displayFolder": "_Formatting",
            "expression": [
              "",
              "VAR metric = SELECTEDVALUE(Metrics[Metric])",
              "",
              "VAR trend_score = ",
              "    SWITCH(",
              "        metric,",
              "        \"Satisfaction Score\", [Trend_Satisfaction],",
              "        \"Wait Time\", [Trend_Wait_Times],",
              "        \"Patient Count\", [Trend_Patient_Count]",
              "    )",
              "",
              "VAR direction = IF(trend_score >= 0, \"Up\", \"Down\")",
              "",
              "VAR output = ",
              "    SWITCH(",
              "        metric,",
              "        \"Satisfaction Score\", metric & \" (Trending \" & direction & \") - Avg: \" & FORMAT( [Avg_Sat_Score], \"#,##0.#0\" ) ,",
              "        \"Wait Time\", metric & \" (Trending \" & direction & \") - Avg: \" & FORMAT( [Avg_Wait_Time], \"#,##0.#0\" ) ,",
              "        \"Patient Count\", metric & \" (Trending \" & direction & \")\"",
              "    )",
              "",
              "RETURN ",
              "    output"
            ],
            "lineageTag": "082b2ba7-74c2-431d-aa7b-1069a5c8fa22"
          },
