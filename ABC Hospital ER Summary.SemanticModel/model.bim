                "    #\"Inserted Date\" = Table.AddColumn(#\"Changed Type\", \"Date\", each DateTime.Date([#\"Date & Time\"]), type date),",
                "    #\"Inserted Time\" = Table.AddColumn(#\"Inserted Date\", \"Time\", each DateTime.Time([#\"Date & Time\"]), type time),",
                "    #\"Removed Columns\" = Table.RemoveColumns(#\"Inserted Time\",{\"month\", \"Hour_of_day\"}),",
                "    #\"Reordered Columns\" = Table.ReorderColumns(#\"Removed Columns\",{\"Date\", \"Time\", \"patient_id\", \"patient_gender\", \"patient_age\", \"patient_first_initial\", \"patient_last_name\", \"patient_race\", \"department_referral\", \"patient_admin_flag\", \"patient_waittime\", \"patient_sat_score\"}),",
                "    #\"Renamed Columns\" = Table.RenameColumns(#\"Reordered Columns\",{{\"patient_admin_flag\", \"patient_admitted\"}, {\"Date & Time\", \"DateTime\"}}),",
                "    #\"Added Conditional Column\" = Table.AddColumn(#\"Renamed Columns\", \"patient_admitted_desc\", each if [patient_admitted] = true then \"Admitted\" else \"Not Admitted\", type text),",
                "    #\"Removed Columns1\" = Table.RemoveColumns(#\"Added Conditional Column\",{\"patient_admitted\"}),",
                "    #\"Replaced Value\" = Table.ReplaceValue(#\"Removed Columns1\",\"M\",\"Male\",Replacer.ReplaceValue,{\"patient_gender\"}),",
                "    #\"Replaced Value1\" = Table.ReplaceValue(#\"Replaced Value\",\"F\",\"Female\",Replacer.ReplaceValue,{\"patient_gender\"})",
                "in",
                "    #\"Replaced Value1\""
              ],
              "type": "m"
            }
