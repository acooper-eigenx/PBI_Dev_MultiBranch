          },
          {
            "name": "Total_Visits",
            "expression": [
              "CALCULATE(",
              "    [Count_Patients],",
              "    ALL( Hospital_Data )",
              ")"
            ],
            "formatString": "#,0",
            "lineageTag": "8394a0a0-c45d-4e7a-be3d-77be1ed8426a"
          },
          {
            "name": "Percent_Of_Total_Visits",
            "expression": [
              "DIVIDE(",
              "    [Count_Patients],",
              "    [Total_Visits],",
              "    0",
              ")"
            ],
            "formatString": "(#,##0.00 %)",
            "lineageTag": "8073f0be-ada5-4937-a5c4-68e3c3d781cd"
          },
          {
