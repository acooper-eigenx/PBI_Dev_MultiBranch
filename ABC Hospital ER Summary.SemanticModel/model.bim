            "name": "Trend_Satisfaction",
            "displayFolder": "_Trends",
            "expression": [
              "VAR Known = ",
              "FILTER (",
              "    SELECTCOLUMNS (",
              "        CALCULATETABLE( VALUES( Calendar[Date] ), ALLSELECTED( Calendar[Date] ) ),",
              "        \"Known[X]\", Calendar[Date],",
              "        \"Known[Y]\", [Avg_Sat_Score]",
              "    ),",
              "    NOT ( ISBLANK ( Known[X] ) ) &&",
              "    NOT ( ISBLANK ( Known[Y] ) )",
              ")",
              "",
              "VAR Count_Items =",
              "    COUNTROWS ( Known )",
              "VAR Sum_X =",
              "    SUMX ( Known, Known[X] )",
              "VAR Sum_X2 =",
              "    SUMX ( Known, Known[X] ^ 2 )",
              "VAR Sum_Y =",
              "    SUMX ( Known, Known[Y] )",
              "VAR Sum_Y2 =",
              "    SUMX ( Known, Known[Y] ^ 2 )",
              "VAR Sum_XY =",
              "    SUMX ( Known, Known[X] * Known[Y] )",
              "",
              "VAR Pearson_Numerator = Sum_XY - DIVIDE(Sum_X * Sum_Y, Count_Items)",
              "VAR Pearson_Denominator = SQRT((Sum_X2 - DIVIDE(Sum_X^2, Count_Items)) * (Sum_Y2 - DIVIDE(Sum_Y^2, Count_Items)))",
              "VAR Pearson_Correlation = DIVIDE(Pearson_Numerator, Pearson_Denominator)",
              "",
              "RETURN",
              "    Pearson_Correlation"
            ],
            "lineageTag": "a69d6caa-0900-47ef-adb0-4f0e702297ee"
          },
          {
            "name": "Trend_Wait_Times",
            "displayFolder": "_Trends",
            "expression": [
              "VAR Known = ",
              "FILTER (",
              "    SELECTCOLUMNS (",
              "        CALCULATETABLE( VALUES( Calendar[Date] ), ALLSELECTED( Calendar[Date] ) ),",
              "        \"Known[X]\", Calendar[Date],",
              "        \"Known[Y]\", [Avg_Wait_Time]",
              "    ),",
              "    NOT ( ISBLANK ( Known[X] ) ) &&",
              "    NOT ( ISBLANK ( Known[Y] ) )",
              ")",
              "",
              "VAR Count_Items =",
              "    COUNTROWS ( Known )",
              "VAR Sum_X =",
              "    SUMX ( Known, Known[X] )",
              "VAR Sum_X2 =",
              "    SUMX ( Known, Known[X] ^ 2 )",
              "VAR Sum_Y =",
              "    SUMX ( Known, Known[Y] )",
              "VAR Sum_Y2 =",
              "    SUMX ( Known, Known[Y] ^ 2 )",
              "VAR Sum_XY =",
              "    SUMX ( Known, Known[X] * Known[Y] )",
              "",
              "VAR Pearson_Numerator = Sum_XY - DIVIDE(Sum_X * Sum_Y, Count_Items)",
              "VAR Pearson_Denominator = SQRT((Sum_X2 - DIVIDE(Sum_X^2, Count_Items)) * (Sum_Y2 - DIVIDE(Sum_Y^2, Count_Items)))",
              "VAR Pearson_Correlation = DIVIDE(Pearson_Numerator, Pearson_Denominator)",
              "",
              "RETURN",
              "    Pearson_Correlation"
            ],
            "lineageTag": "51d48501-3f29-481b-aeec-8df05bf632a8"
          },
          {
            "name": "Trend_Patient_Count",
            "displayFolder": "_Trends",
            "expression": [
              "VAR Known = ",
              "FILTER (",
              "    SELECTCOLUMNS (",
              "        CALCULATETABLE( VALUES( Calendar[Date] ), ALLSELECTED( Calendar[Date] ) ),",
              "        \"Known[X]\", Calendar[Date],",
              "        \"Known[Y]\", [Count_Patients]",
              "    ),",
              "    NOT ( ISBLANK ( Known[X] ) ) &&",
              "    NOT ( ISBLANK ( Known[Y] ) )",
              ")",
              "",
              "VAR Count_Items =",
              "    COUNTROWS ( Known )",
              "VAR Sum_X =",
              "    SUMX ( Known, Known[X] )",
              "VAR Sum_X2 =",
              "    SUMX ( Known, Known[X] ^ 2 )",
              "VAR Sum_Y =",
              "    SUMX ( Known, Known[Y] )",
              "VAR Sum_Y2 =",
              "    SUMX ( Known, Known[Y] ^ 2 )",
              "VAR Sum_XY =",
              "    SUMX ( Known, Known[X] * Known[Y] )",
              "",
              "VAR Pearson_Numerator = Sum_XY - DIVIDE(Sum_X * Sum_Y, Count_Items)",
              "VAR Pearson_Denominator = SQRT((Sum_X2 - DIVIDE(Sum_X^2, Count_Items)) * (Sum_Y2 - DIVIDE(Sum_Y^2, Count_Items)))",
              "VAR Pearson_Correlation = DIVIDE(Pearson_Numerator, Pearson_Denominator)",
              "",
              "RETURN",
              "    Pearson_Correlation"
            ],
            "lineageTag": "da9d1b21-fe0d-4c98-952a-1ec09bdf0831"
          },
          {
            "name": "Trend_Line_Patient_Count",
            "displayFolder": "_Trends",
            "expression": [
              "VAR Known =",
              "    FILTER (",
              "        SELECTCOLUMNS (",
              "            CALCULATETABLE ( VALUES ( Calendar[Date] ), ALLSELECTED (Calendar) ),",
              "            \"Known[X]\", Calendar[Date],",
              "            \"Known[Y]\", [Count_Patients]",
              "        ),",
              "        AND ( NOT ( ISBLANK ( Known[X] ) ), NOT ( ISBLANK ( Known[Y] ) ) )",
              "    )",
              "VAR Count_Items =",
              "    COUNTROWS ( Known )",
              "VAR Sum_X =",
              "    SUMX ( Known, Known[X] )",
              "VAR Sum_X2 =",
              "    SUMX ( Known, Known[X] ^ 2 )",
              "VAR Sum_Y =",
              "    SUMX ( Known, Known[Y] )",
              "VAR Sum_XY =",
              "    SUMX ( Known, Known[X] * Known[Y] )",
              "VAR Average_X =",
              "    AVERAGEX ( Known, Known[X] )",
              "VAR Average_Y =",
              "    AVERAGEX ( Known, Known[Y] )",
              "VAR Slope =",
              "    DIVIDE (",
              "        Count_Items * Sum_XY - Sum_X * Sum_Y,",
              "        Count_Items * Sum_X2 - Sum_X ^ 2",
              "    )",
              "VAR Intercept = Average_Y",
              "    - Slope * Average_X",
              "    ",
              "VAR reg = ",
              "    SUMX ( ",
              "        DISTINCT ( Calendar[Date] ),",
              "        Intercept + Slope * Calendar[Date]",
              "    )",
              "",
              "RETURN",
              "    reg"
            ],
            "lineageTag": "3d7d43eb-8b39-4c10-b30b-87d8dcb409df"
          },
          {
            "name": "Trend_Line_Satisfaction",
